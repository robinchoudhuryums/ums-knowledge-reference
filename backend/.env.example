# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# S3 Configuration
S3_BUCKET=ums-knowledge-reference

# Bedrock Configuration
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
# Haiku 4.5 via cross-region inference profile (required for newer models).
BEDROCK_GENERATION_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
# Sonnet for structured extraction (more accurate for form-filling / clinical note extraction).
BEDROCK_EXTRACTION_MODEL=us.anthropic.claude-sonnet-4-6-20250514-v1:0

# Bedrock Batch Inference (50% cost savings on async-eligible workloads — results delayed up to 24h)
# When enabled AND BEDROCK_BATCH_ROLE_ARN is set, the batch scheduler runs.
# Callers (extraction pipeline — follow-up) can opt into deferred Bedrock calls.
# BEDROCK_BATCH_MODE=true
# BEDROCK_BATCH_ROLE_ARN=arn:aws:iam::123456789012:role/BedrockBatchRole
# BATCH_INTERVAL_MINUTES=15

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS — set to your frontend URL in production
CORS_ORIGIN=http://localhost:5173

# Auth Configuration
JWT_SECRET=change-this-to-a-secure-random-string
# JWT token expiry (HIPAA: short sessions recommended). Default: 30m
JWT_EXPIRY=30m

# ─── SSO with CallAnalyzer (Option A: RAG keeps local users, CA is auth authority) ─
# All off by default — flip all three in a coordinated cutover with CA's matching flags.
# ENABLE_SSO=false
# CA_BASE_URL=https://umscallanalyzer.com
# SHARED_COOKIE_DOMAIN=.umscallanalyzer.com
# ENABLE_NATIVE_MFA=true  # flip to false once SSO is stable — CA enforces MFA before session exists

# ─── Embed mode (Track 3 — CallAnalyzer iframes RAG's chat at /?embed=1) ─
# Allowlist for CSP frame-ancestors. When set, CA's origin can iframe this
# service; X-Frame-Options is disabled so CSP is the sole authority.
# Unset = default-deny framing (frame-ancestors 'none').
# EMBED_ALLOWED_ORIGIN=https://umscallanalyzer.com

# Rate Limiting (optional — defaults shown)
# RATE_LIMIT_PER_USER_MAX=60
# RATE_LIMIT_GLOBAL_MAX=120

# File Upload (optional)
# MAX_FILE_UPLOAD_SIZE_MB=50

# Malware Scanning (optional — requires ClamAV daemon)
# MALWARE_SCAN_ENABLED=true
# CLAMAV_HOST=localhost
# CLAMAV_PORT=3310

# Fee Schedule (optional)
# CMS_FEE_SCHEDULE_URL=https://...
# FEE_SCHEDULE_FETCH_INTERVAL_HOURS=168

# ─── PostgreSQL Database (RDS) ───────────────────────────────────────────────
# Option 1: Full connection string (preferred for Render/Heroku)
# DATABASE_URL=postgresql://ums_user:password@your-rds-host.region.rds.amazonaws.com:5432/ums_knowledge?sslmode=require
#
# Option 2: Individual variables
# DB_HOST=your-rds-host.region.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=ums_knowledge
# DB_USER=ums_user
# DB_PASSWORD=your-secure-password
# DB_SSL=true
# DB_POOL_MAX=10

# ─── Field Encryption (optional — for PHI/secrets at rest) ───────────────────
# Encrypts sensitive fields (MFA secrets) with AES-256-GCM before database storage.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# FIELD_ENCRYPTION_KEY=your-64-char-hex-string

# ─── Redis (optional — for horizontal scaling) ──────────────────────────────
# When set, token revocation, rate limiting, and embedding cache are shared
# across multiple instances. Without it, these use in-memory stores (single-instance).
# REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://your-elasticache-host:6379   # TLS for ElastiCache
# REDIS_KEY_PREFIX=ums:                             # Key namespace (default: ums:)

# SMTP Email (optional — for form submission emails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@universalmedsupply.com
# SMTP_PASS=app-specific-password
# SMTP_FROM=noreply@universalmedsupply.com

# Data Retention (optional — HIPAA minimum floors enforced automatically)
# RETENTION_AUDIT_DAYS=2555
# RETENTION_QUERY_LOG_DAYS=365
# RETENTION_RAG_TRACE_DAYS=90
# RETENTION_FEEDBACK_DAYS=365
