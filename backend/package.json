{
  "name": "ums-knowledge-base-backend",
  "version": "1.0.0",
  "description": "HIPAA-compliant knowledge base and RAG backend for UMS",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
